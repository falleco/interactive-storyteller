{
  "name": "@wondertales/api",
  "version": "1.0.0",
  "private": true,
  "description": "Wonder Tales backend API (NestJS)",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "tsc": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@better-auth/expo": "^1.2.0",
    "@keyv/redis": "^4.0.0",
    "@liaoliaots/nestjs-redis-health": "^9.0.4",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/cache-manager": "^3.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "@wondertales/shared": "workspace:*",
    "better-auth": "^1.2.0",
    "bullmq": "^5.0.0",
    "cache-manager": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "keyv": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.7.0",
    "@swc/jest": "^0.2.36",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "mjs",
      "cjs",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx|mjs|cjs)$": [
        "@swc/jest",
        {
          "jsc": {
            "parser": {
              "syntax": "typescript",
              "decorators": true,
              "dynamicImport": true
            },
            "transform": {
              "legacyDecorator": true,
              "decoratorMetadata": true
            },
            "target": "es2022",
            "keepClassNames": true
          },
          "module": {
            "type": "commonjs"
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(better-auth|@better-auth|better-call|@better-fetch|rou3|jose|@noble|@scure|nanoid|uncrypto|defu|consola|ofetch|pathe|destr|ufo|keyv|@keyv|cacheable)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!main.ts",
      "!config/**",
      "!prisma/**",
      "!**/*.module.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
