PORT=3000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wondertales?schema=public"

# Redis (used by BullMQ for background jobs)
REDIS_URL="redis://localhost:6379"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-random-32-byte-secret
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of origins allowed to call /api/auth/*
# Add your Expo scheme so OAuth callbacks back to the mobile app are trusted.
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081,wondertales://
# Note: with the @better-auth/expo server plugin enabled, the Expo scheme is
# also auto-added — but keeping it explicit here doesn't hurt.

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth — https://developer.apple.com/account/resources/identifiers/list/serviceId
# clientId: Services ID (e.g. com.wondertalesai.auth)
# clientSecret: a signed JWT generated from your Apple private key
# appBundleIdentifier: your iOS app bundle ID, enables native Sign in with Apple
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_BUNDLE_IDENTIFIER=com.wondertalesai.app

# AI providers
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# Default capability routing (override to switch providers per capability)
AI_TEXT_PROVIDER=openai
AI_IMAGE_PROVIDER=replicate
AI_SPEECH_PROVIDER=replicate

# Default models per capability (any model identifier the chosen provider accepts)
AI_TEXT_MODEL=gpt-4o-mini
AI_IMAGE_MODEL=black-forest-labs/flux-2-klein-4b
AI_SPEECH_MODEL=minimax/speech-2.8-turbo

# S3-compatible object storage (Cloudflare R2 supported)
S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Required for R2 / non-AWS — leave blank for AWS S3
S3_ENDPOINT=
# Optional CDN/custom-domain URL prefix used when serving uploaded objects
S3_PUBLIC_BASE_URL=
