{
  "moduleFileExtensions": ["js", "mjs", "cjs", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(ts|tsx|js|jsx|mjs|cjs)$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true,
            "dynamicImport": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2022",
          "keepClassNames": true
        },
        "module": {
          "type": "commonjs"
        }
      }
    ]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(better-auth|@better-auth|better-call|@better-fetch|rou3|jose|@noble|@scure|nanoid|uncrypto|defu|consola|ofetch|pathe|destr|ufo|keyv|@keyv|cacheable)/)"
  ]
}
