{
  "name": "@wondertales/root",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.10.3+sha512.c38cafb5c7bb273f3926d04e55e1d8c9dfa7d9c3ea1f36a4868fa028b9e5f72298f0b7f401ad5eb921749eb012eb1c3bb74bf7503df3ee43fd600d14a018266f",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "yarn workspace @wondertales/mobile",
    "api": "yarn workspace @wondertales/api",
    "shared": "yarn workspace @wondertales/shared",
    "dev:mobile": "yarn workspace @wondertales/mobile start",
    "dev:api": "yarn workspace @wondertales/api start:dev",
    "build": "yarn workspaces foreach -A --topological-dev --exclude @wondertales/root run build",
    "tsc": "yarn workspaces foreach -A --exclude @wondertales/root run tsc",
    "test": "yarn workspaces foreach -A --exclude @wondertales/root run test",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "jose": "^6.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
